<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- Exclude the local source of truth and preferences from cloud backup: media/reports
         contain location data and must not leave the device implicitly (PERMISSIONS_PRIVACY). -->
    <exclude domain="database" path="geosnap.db" />
    <exclude domain="database" path="geosnap.db-shm" />
    <exclude domain="database" path="geosnap.db-wal" />
    <exclude domain="sharedpref" path="." />
    <exclude domain="file" path="datastore/" />
    <exclude domain="file" path="reports/" />
    <exclude domain="external" path="." />
</full-backup-content>
