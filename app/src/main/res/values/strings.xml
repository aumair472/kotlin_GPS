    <!-- Legal -->
    <string name="legal_privacy_title">Privacy Policy</string>
    <string name="legal_terms_title">Terms &amp; Conditions</string>
    <string name="privacy_policy_url">https://sites.google.com/view/gpscameratimestampmap/home</string>
    <string name="terms_url">https://sites.google.com/view/gps-camera-timestamp-map/home</string>
    <string name="legal_privacy_body">GPS Camera: Timestamp &amp; Map processes your photos, videos, location, and report content entirely on your device by default. Location is used only while the camera screen is active or at capture time to stamp captures with coordinates; GPS Camera: Timestamp &amp; Map does not use background location. Captured media may embed visible stamps and EXIF GPS/time metadata. Exported or shared files may reveal location to recipients and are outside the app\'s control once shared. GPS Camera: Timestamp &amp; Map does not upload your coordinates, media, notes, or identifiers in this release. You can delete media and reports from within the app at any time; copies you have already shared or exported are not affected.</string>
    <string name="legal_terms_body">GPS Camera: Timestamp &amp; Map is provided as a field documentation tool. GPS coordinates and device clocks can be manipulated on consumer devices; GPS Camera: Timestamp &amp; Map records location and time evidence and consistency signals but does not provide cryptographic proof of physical presence. Use captured records accordingly. You are responsible for complying with local laws regarding photography, recording, and privacy when using this app.</string>

